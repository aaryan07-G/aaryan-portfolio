# ─────────────────────────────────────────────────────────────────────────────
# EmailJS credentials — required for the contact form to actually send email.
#
# Setup (takes ~5 minutes):
#   1. https://www.emailjs.com → sign up (free tier is enough)
#   2. Email Services → Add New → Gmail → connect aaaryanxdrive@gmail.com
#      Copy: SERVICE ID  (format: service_xxxxxxx)
#   3. Email Templates → Create New Template
#      Set:  To Email   = aaaryanxdrive@gmail.com
#            From Name  = {{from_name}}
#            Reply To   = {{from_email}}
#            Subject    = New message from {{from_name}}
#            Body:
#              Name:   {{from_name}}
#              Email:  {{from_email}}
#              Budget: {{budget}}
#
#              {{message}}
#      Save. Copy: TEMPLATE ID  (format: template_xxxxxxx)
#   4. Account → General → Public Key
#      Copy: PUBLIC KEY  (20-char string)
#   5. Paste the three values below, save as .env.local (NOT .env.local.example)
#   6. RESTART the dev server:  Ctrl+C  →  npm run dev
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=XXXXXXXXXXXXXXXXXXXX
